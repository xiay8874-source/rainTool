{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "../dist-electron",
    "rootDir": "."
  },
  "include": [
    "./main.ts",
    "./ai-drawio-service.ts",
    "./ai-drawio-types.d.ts",
    "./diagram-types.ts",
    "./diagram-repository.ts",
    "./diagram-bridge-server.ts",
    "./ai-platform/**/*.ts"
  ]
}
