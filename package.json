{
  "name": "raintool",
  "productName": "RainTool",
  "version": "0.2.6",
  "description": "程序员开发工具百宝箱",
  "main": "dist-electron/main.js",
  "author": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "npm run dev",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -p electron/tsconfig.json && tsc -p electron/tsconfig.preload.json",
    "build:ai": "node scripts/build-next-standalone.mjs",
    "verify:ai": "node scripts/verify-next-standalone.mjs",
    "verify:package:ai": "node scripts/verify-packaged-ai.mjs",
    "preview": "vite preview",
    "start": "npm run start:prod",
    "start:prod": "npm run build:ai && npm run build && npm run build:electron && electron .",
    "dist": "npm run build:ai && npm run build && npm run build:electron && electron-builder --mac && npm run verify:package:ai"
  },
  "build": {
    "appId": "com.xiay8874.raintool",
    "productName": "RainTool",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/next-standalone",
        "to": "next-standalone",
        "filter": [
          "**/*",
          "!**/node_modules",
          "!**/node_modules/**"
        ]
      },
      {
        "from": "build/next-standalone/node_modules",
        "to": "next-standalone/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "LICENSES",
        "to": "licenses"
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "${productName} ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
